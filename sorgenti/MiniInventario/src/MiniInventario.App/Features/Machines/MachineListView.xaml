<UserControl x:Class="MiniInventario.App.Features.Machines.MachineListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="1100">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                Padding="20"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                Margin="0,0,0,16">

            <StackPanel>
                <TextBlock Text="MiniInventario"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"/>

                <TextBlock Text="Gestione semplice di macchine, utenti assegnati e posizioni"
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Barra ricerca/comandi -->
        <Grid Grid.Row="1"
                Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <TextBox Height="36"
                         FontSize="14"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Cerca per nome macchina, utente o posizione"/>

                <TextBlock Text="Cerca per nome macchina, utente o posizione..."
                           Foreground="#94A3B8"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility"
                                    Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchEmpty}"
                                        Value="True">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Button Grid.Column="1"
                    Content="Nuova macchina"
                    Width="140"
                    Margin="10,0,0,0"
                    Command="{Binding NewCommand}"/>

            <Button Grid.Column="2"
                    Content="Aggiorna"
                    Width="100"
                    Margin="10,0,0,0"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <!-- Corpo principale -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Lista -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">

                <Grid>
                    <DataGrid ItemsSource="{Binding Machines}"
                              SelectedItem="{Binding SelectedMachine, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal"
                              AlternationCount="2">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nome macchina"
                                                Binding="{Binding Name}"
                                                Width="2*"/>

                            <DataGridTextColumn Header="Utente"
                                                Binding="{Binding AssignedUser}"
                                                Width="1.5*"/>

                            <DataGridTextColumn Header="Posizione"
                                                Binding="{Binding Location}"
                                                Width="1.5*"/>

                            <DataGridTextColumn Header="Ultima modifica"
                                                Binding="{Binding UpdatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                                Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Machines.Count}"
                                            Value="0">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <TextBlock Text="Nessuna macchina presente"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#334155"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Inserisci una nuova macchina usando il pannello a destra."
                                       Foreground="#64748B"
                                       Margin="0,6,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Dettaglio -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding FormTitle}"
                               FontSize="21"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               Margin="0,0,0,18"/>

                    <StackPanel Grid.Row="1"
                            Margin="0,0,0,12">
                        <TextBlock Text="Nome macchina"
                                   Foreground="#334155"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                            Margin="0,0,0,12">
                        <TextBlock Text="Utente assegnato"
                                   Foreground="#334155"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding AssignedUser, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3"
                            Margin="0,0,0,12">
                        <TextBlock Text="Posizione"
                                   Foreground="#334155"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4"
                            Margin="0,0,0,12">
                        <TextBlock Text="Note"
                                   Foreground="#334155"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Height="120"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="5"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0">

                        <Button Content="Salva"
                                Width="90"
                                Command="{Binding SaveCommand}"/>

                        <Button Content="Elimina"
                                Width="90"
                                Margin="10,0,0,0"
                                Background="#DC2626"
                                BorderBrush="#B91C1C"
                                Command="{Binding DeleteCommand}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6"
                            Margin="0,16,0,0">

                        <Border Background="#FEF2F2"
                                BorderBrush="#FECACA"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ErrorMessage}"
                                                Value="">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ErrorMessage}"
                                                Value="{x:Null}">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#991B1B"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Background="#ECFDF5"
                                BorderBrush="#BBF7D0"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusMessage}"
                                                Value="">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusMessage}"
                                                Value="{x:Null}">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="#166534"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="3"
                   Text="Dati salvati localmente in Data/machines.json"
                   Foreground="#777777"
                   FontSize="12"
                   Margin="0,12,0,0"/>
    </Grid>
</UserControl>