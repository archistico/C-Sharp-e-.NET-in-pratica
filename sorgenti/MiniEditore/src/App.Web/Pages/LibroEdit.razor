@page "/libri/nuovo"
@page "/libri/{Id:int}"
@inject CatalogoApiClient Api
@inject NavigationManager Nav
@using global::App.Web.Components

@if (isLoading)
{
    <LoadingPanel IsLoading="true" />
}
else
{
    <PageHeader Title="Modifica/Creazione Libro" />

    <div class="card">
        <div class="form-grid">
            <div class="form-field">
                <label>Titolo</label>
                <input @bind="model.Titolo" />
            </div>
            <div class="form-field">
                <label>ISBN</label>
                <input @bind="model.Isbn" />
            </div>
            <div class="form-field">
                <label>Prezzo</label>
                <input type="number" step="0.01" @bind="model.Prezzo" />
            </div>
        </div>

        <div style="margin-top:1rem">
            <button class="btn btn-primary" @onclick="Save">Salva</button>
            <a class="btn btn-secondary" href="/libri" style="margin-left:0.5rem">Annulla</a>
        </div>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }

    private bool isLoading = true;
    private LibroFormModel model = new();

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            LibroDetailDto? dettaglio = await Api.GetLibroAsync(Id.Value);
            if (dettaglio is not null)
            {
                model = new LibroFormModel
                {
                    Titolo = dettaglio.Titolo,
                    Isbn = dettaglio.Isbn,
                    Prezzo = dettaglio.Prezzo,
                    DataPubblicazione = dettaglio.DataPubblicazione,
                    CollanaId = null,
                    AutoriIds = Array.Empty<int>(),
                    Attivo = dettaglio.Attivo
                };
            }
        }

        isLoading = false;
    }

    private async Task Save()
    {
        if (Id.HasValue)
        {
            UpdateLibroRequest request = new(
                model.Titolo,
                model.Isbn,
                model.Prezzo,
                model.DataPubblicazione,
                model.CollanaId,
                model.AutoriIds,
                model.Attivo);

            await Api.UpdateLibroAsync(Id.Value, request);
        }
        else
        {
            CreateLibroRequest request = new(
                model.Titolo,
                model.Isbn,
                model.Prezzo,
                model.DataPubblicazione,
                model.CollanaId,
                model.AutoriIds);

            await Api.CreateLibroAsync(request);
        }

        Nav.NavigateTo("/libri");
    }

    private sealed class LibroFormModel
    {
        public string Titolo { get; set; } = string.Empty;
        public string? Isbn { get; set; }
        public decimal Prezzo { get; set; }
        public DateOnly? DataPubblicazione { get; set; }
        public int? CollanaId { get; set; }
        public IReadOnlyList<int> AutoriIds { get; set; } = Array.Empty<int>();
        public bool Attivo { get; set; } = true;
    }
}
